def run_hfc_tests():
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  HyperMorphic Fountain Code — Test Suite                            ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")

    hfc = HyperMorphicFountainCode(
        geometry_dim=4,
        E_levels=9,
        symbol_bytes=16,
    )

    results = []

    def section(title):
        print("\n" + "─" * 78)
        print(" ", title)
        print("─" * 78)

    def check(name, ok, note=""):
        results.append(bool(ok))
        icon = "✅" if ok else "❌"
        print(f"  {icon} {name:<68} {note}")

    # 1. Basic fountain roundtrip
    section("1. BASIC FOUNTAIN ROUNDTRIP")

    cases = [
        ("short", b"HyperMorphic Fountain Codes"),
        ("zeros", bytes(512)),
        ("random 1KB", os.urandom(1024)),
        ("pattern", b"HFC-" * 300),
    ]

    for name, data in cases:
        droplets = hfc.encode(data)
        recovered, cert = hfc.decode_with_certificate(droplets)

        check(
            f"Roundtrip: {name}",
            recovered == data,
            f"K={cert['K']} used={cert['droplets_used']} overhead={cert['overhead_ratio']}",
        )

    # 2. Same count, different geometry
    section("2. SAME COUNT, DIFFERENT GEOMETRY")

    data = os.urandom(512)
    droplets = hfc.encode(data, droplet_count=220)

    # Find a valid full-span prefix.
    good = None
    good_cert = None

    for n in range(len(hfc._symbols(data)), len(droplets) + 1):
        candidate = droplets[:n]

        try:
            recovered, cert = hfc.decode_with_certificate(
                candidate,
                incremental=False,
            )

            if recovered == data:
                good = candidate
                good_cert = cert
                break

        except Exception:
            pass

    check(
        "Found full-span valid fountain corridor",
        good is not None,
        f"N={len(good) if good else None}",
    )

    N = len(good)

    # Same number of droplets, but clustered into lanes 0/1 only.
    clustered = [d for d in droplets if d.lane in {0, 1}][:N]
    clustered_metrics = hfc.corridor_metrics(clustered)

    try:
        hfc.decode_with_certificate(clustered, incremental=False)
        clustered_rejected = False
    except Exception:
        clustered_rejected = True

    check(
        "Same-count clustered droplet set rejected",
        clustered_rejected,
        (
            f"N={N}, lanes={clustered_metrics.get('lanes')}, "
            f"required_lanes={clustered_metrics.get('required_lanes')}"
        ),
    )

    check(
        "Good set and bad set have same droplet count",
        len(good) == len(clustered),
        f"good={len(good)} bad={len(clustered)}",
    )

    # 3. Droplet loss tolerance
    section("3. DROPLET LOSS TOLERANCE")

    data = os.urandom(2048)
    droplets = hfc.encode(data, droplet_count=260)

    kept = hfc.drop_random(droplets, drop_fraction=0.30, seed=42)

    recovered, cert = hfc.decode_with_certificate(kept)

    check(
        "Decode after 30% random droplet loss",
        recovered == data,
        f"kept={len(kept)} used={cert['droplets_used']}",
    )

    # 4. Tamper filtering
    section("4. TAMPER FILTERING")

    data = b"corrupt-check" * 200
    droplets = hfc.encode(data, droplet_count=180)

    corrupted = hfc.corrupt_droplets(droplets, [0, 3, 8])

    recovered, cert = hfc.decode_with_certificate(corrupted)

    check(
        "HMAC skips corrupted droplets and still recovers",
        recovered == data,
        f"valid_droplets={cert['valid_droplets_available']}",
    )

    # 5. Streaming fountain recovery
    section("5. STREAMING FOUNTAIN RECOVERY")

    data = os.urandom(1536)

    stream = hfc.droplet_stream(data)

    collected = []

    recovered = None
    cert = None

    for _ in range(300):
        collected.append(next(stream))

        try:
            recovered, cert = hfc.decode_with_certificate(collected)
            break
        except Exception:
            pass

    check(
        "Streaming decode eventually completes corridor",
        recovered == data,
        f"collected={len(collected)} used={cert['droplets_used'] if cert else None}",
    )

    # 6. Certificate fields
    section("6. CERTIFICATE STRUCTURE")

    data = os.urandom(700)
    droplets = hfc.encode(data)
    recovered, cert = hfc.decode_with_certificate(droplets)

    required_fields = [
        "K",
        "droplets_used",
        "overhead_ratio",
        "rank",
        "lanes",
        "corridor_score",
        "required_lanes",
        "lane_distribution",
        "degree_distribution",
    ]

    check(
        "Certificate includes key corridor fields",
        all(k in cert for k in required_fields),
        f"fields={len(cert)}",
    )

    print("\n  Certificate sample:")
    for k in [
        "K",
        "droplets_used",
        "overhead_ratio",
        "rank",
        "lanes",
        "corridor_score",
        "required_lanes",
        "lane_distribution",
        "seed_range",
    ]:
        print(f"    {k}: {cert[k]}")

    # Summary
    section("SUMMARY")

    passed = sum(results)
    total = len(results)

    print(f"  RESULTS: {passed}/{total} passed")

    if passed == total:
        print("  ✅ ALL PASS — HFC primitive validated")
    else:
        print(f"  ❌ {total - passed} failures")

    return passed == total


