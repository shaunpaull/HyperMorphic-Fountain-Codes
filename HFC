# SECTION 1 — FINITE FIELD FOUNDATION
# ═══════════════════════════════════════════════════════════════════════

GF_P = 257
# GF(257) is used because byte values 0..255 embed directly into the field.


def modinv(a: int, m: int) -> int:
    return pow(a % m, -1, m)


def shannon_entropy(data: bytes) -> float:
    if not data:
        return 0.0

    n = len(data)
    counts = Counter(data)

    return -sum((c / n) * math.log2(c / n) for c in counts.values())


def shake128_int(seed: bytes, byte_len: int = 8) -> int:
    return int.from_bytes(hashlib.shake_128(seed).digest(byte_len), "big")


def sha256_hex(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def matrix_rank_modp(A: List[List[int]], n_cols: int, p: int = GF_P) -> int:
    """
    Row-rank over GF(p).
    """
    if not A:
        return 0

    M = [row[:n_cols].copy() for row in A]
    r = 0

    for c in range(n_cols):
        pivot = None

        for i in range(r, len(M)):
            if M[i][c] % p != 0:
                pivot = i
                break

        if pivot is None:
            continue

        M[r], M[pivot] = M[pivot], M[r]

        inv = modinv(M[r][c], p)
        M[r] = [(v * inv) % p for v in M[r]]

        for i in range(len(M)):
            if i != r and M[i][c] % p != 0:
                factor = M[i][c] % p
                M[i] = [
                    (M[i][j] - factor * M[r][j]) % p
                    for j in range(n_cols)
                ]

        r += 1

        if r == n_cols:
            break

    return r


def solve_linear_system_modp(
    A: List[List[int]],
    Y: List[List[int]],
    n_vars: int,
    p: int = GF_P,
) -> List[List[int]]:
    """
    Solve A X = Y over GF(p).

    A is m × n_vars.
    Y is m × symbol_bytes.
    X is n_vars × symbol_bytes.

    This solves all byte positions at once using Gaussian elimination
    on the augmented matrix.
    """
    if not A:
        raise ValueError("empty system")

    B = len(Y[0])
    total = n_vars + B

    M = [
        A[i][:n_vars].copy() + Y[i].copy()
        for i in range(len(A))
    ]

    r = 0
    pivots = []

    for c in range(n_vars):
        pivot = None

        for i in range(r, len(M)):
            if M[i][c] % p != 0:
                pivot = i
                break

        if pivot is None:
            continue

        M[r], M[pivot] = M[pivot], M[r]

        inv = modinv(M[r][c], p)
        M[r] = [(v * inv) % p for v in M[r]]

        for i in range(len(M)):
            if i != r and M[i][c] % p != 0:
                factor = M[i][c] % p
                M[i] = [
                    (M[i][j] - factor * M[r][j]) % p
                    for j in range(total)
                ]

        pivots.append(c)
        r += 1

        if r == n_vars:
            break

    if r < n_vars:
        raise ValueError(f"rank deficient: rank={r}, need={n_vars}")

    X = [[0] * B for _ in range(n_vars)]

    for row, col in enumerate(pivots):
        X[col] = [v % p for v in M[row][n_vars:]]

    return X


